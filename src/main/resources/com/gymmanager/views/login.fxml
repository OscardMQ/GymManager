<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
  login.fxml — Formulario de acceso al sistema.
  Raíz: StackPane para centrar la tarjeta sobre el fondo oscuro.
-->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.gymmanager.controllers.LoginController"
           styleClass="login-root">

    <stylesheets>
        <URL value="@../css/login.css"/>
    </stylesheets>

    <!-- Tarjeta central del formulario -->
    <VBox styleClass="login-card" alignment="CENTER" spacing="18"
          maxWidth="380" minWidth="340">

        <padding>
            <Insets top="48" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Encabezado -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="💪" styleClass="login-icono"/>
            <Label text="GymManager - Gen-Fit" styleClass="login-titulo"/>
            <Label text="Sistema de Gestión de Gimnasio" styleClass="login-subtitulo"/>
        </VBox>

        <Separator styleClass="login-separador"/>

        <!-- Campo usuario -->
        <VBox spacing="6">
            <Label text="USUARIO" styleClass="campo-etiqueta"/>
            <TextField fx:id="campoUsuario"
                       promptText="Nombre de usuario"
                       styleClass="campo-texto"/>
        </VBox>

        <!-- Campo contraseña -->
        <VBox spacing="6">
            <Label text="CONTRASEÑA" styleClass="campo-etiqueta"/>
            <PasswordField fx:id="campoContrasena"
                           promptText="••••••••"
                           styleClass="campo-texto"/>
        </VBox>

        <!-- Error (oculto por defecto, gestionado por controller) -->
        <Label fx:id="etiquetaError"
               styleClass="error-etiqueta"
               wrapText="true"
               visible="false"
               managed="false"
               maxWidth="300"/>

        <!-- Botón principal -->
        <Button fx:id="botonIngresar"
                text="INGRESAR"
                styleClass="boton-login"
                maxWidth="Infinity"
                onAction="#handleLogin"/>

        <Label text="GymManager v1.0 © 2026" styleClass="version-etiqueta"/>
    </VBox>
</StackPane>